#!/bin/bash
# ocoreai pre-commit hook вЂ” build gate before every commit
# Exit 1 blocks the commit. Exit 0 lets it through.

# в”Ђв”Ђ Fast path: skip if only docs/scripts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(swift$|Package\.swift|Package\.resolved|xcprivacy|yml$|ya?ml$|json$|toml$)' || {
    echo "вњ… [pre-commit] Only docs/config вЂ” skipping build gate."
    exit 0
}

# в”Ђв”Ђ Package.swift changed? Resolve first в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if git diff --cached --name-only --diff-filter=ACM | grep -qE 'Package\.swift|Package\.resolved'; then
    echo "рџ“¦ [pre-commit] Package changed вЂ” resolving..."
    if ! swift package resolve 2>&1; then
        echo "вќЊ [pre-commit] swift package resolve failed. Aborting commit."
        exit 1
    fi
fi

# в”Ђв”Ђ Build gate в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "рџ”Ё [pre-commit] swift build --traits mlx ..."
if swift build --traits mlx 2>&1 | tee /tmp/ocoreai-build.log | grep -qE 'error:'; then
    echo "вќЊ [pre-commit] Build failed вЂ” commit blocked."
    exit 1
fi

echo "вњ… [pre-commit] Build passed (exit 0). Commit allowed."
exit 0
