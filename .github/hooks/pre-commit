#!/usr/bin/env bash
# pre-commit — block before invalid commits land
set -euo pipefail

# ── 1. Conventional commit format check ──────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel)
COMMIT_MSG_FILE="${REPO_ROOT}/.git/COMMIT_EDITMSG"

if [ -f "$COMMIT_MSG_FILE" ]; then
  MSG=$(grep -v '^#' "$COMMIT_MSG_FILE" | head -1)
  
  # Allow merge commits through
  if [[ "$MSG" == Merge* ]]; then
    exit 0
  fi

  # Conventional commit pattern: type(scope): message  |  type: message
  # Allowed types: feat, fix, test, docs, refactor, chore, style, lint, infra, dep
  if ! echo "$MSG" | grep -qE '^(feat|fix|test|docs|refactor|chore|style|lint|infra|dep)(\(.+\))?: .+'; then
    echo ""
    echo "❌ Commit message does not follow Conventional Commits format:"
    echo ""
    echo "   Got:      $MSG"
    echo "   Expected: type(scope): description"
    echo "   Types:    feat, fix, test, docs, refactor, chore, style, lint, infra, dep"
    echo "   Examples:"
    echo "             feat(client): add streaming cancellation support"
    echo "             fix(reasoning): correct complexity score calculation"
    echo "             test(profiling): add PerRequestMetrics unit tests"
    echo ""
    exit 1
  fi
fi

# ── 2. Secret scanning (if gitleaks available) ───────────────────
if command -v gitleaks >/dev/null 2>&1; then
  CONFIG="${REPO_ROOT}/.gitleaks.toml"
  cfg_args=()
  [[ -f "$CONFIG" ]] && cfg_args+=(--config "$CONFIG")
  gitleaks protect --staged --redact "${cfg_args[@]}"
fi
