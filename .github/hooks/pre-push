#!/usr/bin/env bash
# pre-push — fast gate before push
# debug build (not release) — release takes too long on every push
# tests — last line must report "passed after"

# Local beta-SDK escape hatch: macOS 27 beta SDKs ship CoreAI.framework without a
# compilable module, which breaks the CoreAI backend compile locally. Force it off
# for the local gate so the project builds (MLX path only). CI does not run this
# hook and has no CoreAI.framework, so its behavior is unchanged.
export OCOREAI_DISABLE_COREAI=1

echo "🔧 Pre-push: debug build..."
BUILD_OK=$(swift build 2>&1 | tail -1 | grep -c "Build complete")
if [ "$BUILD_OK" -eq 0 ]; then
  echo "⚠️  Incremental build failed — retrying clean build..."
  rm -rf .build
  BUILD_OK=$(swift build 2>&1 | tail -1 | grep -c "Build complete")
fi
if [ "$BUILD_OK" -eq 0 ]; then
  echo "❌ Build failed"
  exit 1
fi

echo "🧪 Pre-push: tests..."
TEST_LOG="$TMPDIR/.hermes-pre-push-tests.log"
TEST_OK=$(swift test 2>&1 | tee "$TEST_LOG" | tail -1 | grep -c "passed after")
if [ "$TEST_OK" -eq 0 ]; then
  echo "❌ Tests failed — see full log above"
  rm -f "$TEST_LOG"
  exit 1
fi
rm -f "$TEST_LOG"

echo "✅ Pre-push: green"
